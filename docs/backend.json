
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "AppStats": {
      "title": "AppStats",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalReminders": { "type": "number" },
        "activeUsers24h": { "type": "number" }
      }
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the FynWealth application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "stats": {
          "type": "object",
          "properties": {
            "totalExpenses": { "type": "number" },
            "totalReminders": { "type": "number" }
          }
        }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "note": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "Admin",
          "schema": { "$ref": "#/backend/entities/Admin" },
          "description": "Stores authorized admin emails."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profiles and stats."
        }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": { "$ref": "#/backend/entities/Expense" },
          "description": "User expense subcollection."
        }
      },
      {
        "path": "/analytics/appStats",
        "definition": {
          "entityName": "AppStats",
          "schema": { "$ref": "#/backend/entities/AppStats" },
          "description": "Global application metrics."
        }
      }
    ]
  }
}
