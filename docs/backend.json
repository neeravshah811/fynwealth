
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and general settings within the FynWealth application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredCurrency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "AppStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppStats",
      "type": "object",
      "description": "Global application metrics used for the admin dashboard.",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalReminders": { "type": "number" },
        "activeUsers24h": { "type": "number" }
      }
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Records individual spending transactions with specific category structure.",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "note": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "subcategoryName": { "type": "string" },
        "date": { "type": "object", "description": "Firestore Timestamp object." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "categoryId", "categoryName", "subcategoryId", "subcategoryName", "date"]
    },
    "Bill": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bill",
      "type": "object",
      "description": "Recurring bill reminders with specific category structure.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "dueTime": { "type": "string" },
        "frequency": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "subcategoryName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "notified": { "type": "boolean" },
        "attachmentData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "System category for expenses.",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "Subcategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subcategory",
      "type": "object",
      "description": "System subcategory linked to a category.",
      "properties": {
        "name": { "type": "string" },
        "categoryId": { "type": "string" }
      }
    },
    "Folder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Folder",
      "type": "object",
      "description": "Folders for organizing documents in the vault.",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/categories/{categoryId}",
        "definition": { "entityName": "Category", "description": "Global categories." }
      },
      {
        "path": "/subcategories/{subcategoryId}",
        "definition": { "entityName": "Subcategory", "description": "Global subcategories." }
      },
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "description": "User profiles." }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Spending records." }
      },
      {
        "path": "/users/{userId}/bills/{billId}",
        "definition": { "entityName": "Bill", "description": "Recurring bill reminders." }
      },
      {
        "path": "/users/{userId}/folders/{folderId}",
        "definition": { "entityName": "Folder", "description": "Document vault folders." }
      }
    ]
  }
}
