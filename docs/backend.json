
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and general settings within the FynWealth application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredCurrency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "AppStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppStats",
      "type": "object",
      "description": "Global application metrics used for the admin dashboard.",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalReminders": { "type": "number" },
        "activeUsers24h": { "type": "number" }
      }
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Records individual spending transactions with specific category structure.",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "note": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "subcategoryName": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "Transaction date in YYYY-MM-DD format." },
        "createdAt": { "type": "string", "format": "date-time" },
        "billImageData": { "type": "string", "description": "Base64 encoded image or PDF data." },
        "productName": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date" },
        "warrantyExpiryDate": { "type": "string", "format": "date" },
        "serviceCentreContact": { "type": "string" }
      },
      "required": ["userId", "amount", "categoryId", "categoryName", "subcategoryId", "subcategoryName", "date"]
    },
    "Bill": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bill",
      "type": "object",
      "description": "Recurring bill reminders with specific category structure.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "dueTime": { "type": "string" },
        "frequency": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "subcategoryName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "notified": { "type": "boolean" },
        "attachmentData": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "System category for expenses.",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string", "description": "Optional owner ID for custom categories." }
      }
    },
    "Subcategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subcategory",
      "type": "object",
      "description": "System subcategory linked to a category.",
      "properties": {
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "userId": { "type": "string", "description": "Optional owner ID for custom subcategories." }
      }
    },
    "Folder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Folder",
      "type": "object",
      "description": "Folders for organizing documents in the vault.",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "BlacklistedUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BlacklistedUser",
      "type": "object",
      "description": "Records users who have been banned or deleted by an administrator to prevent re-login.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["uid", "email", "deletedAt"]
    },
    "AIUsage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AIUsage",
      "type": "object",
      "description": "Tracks monthly AI usage per user for quota management.",
      "properties": {
        "userId": { "type": "string" },
        "month": { "type": "string", "description": "Format: YYYY-MM" },
        "count": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "month", "count"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/categories/{categoryId}",
        "definition": { "entityName": "Category", "description": "Global or user-defined categories." }
      },
      {
        "path": "/subcategories/{subcategoryId}",
        "definition": { "entityName": "Subcategory", "description": "Global or user-defined subcategories." }
      },
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "description": "User profiles." }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Spending records." }
      },
      {
        "path": "/users/{userId}/bills/{billId}",
        "definition": { "entityName": "Bill", "description": "Recurring bill reminders." }
      },
      {
        "path": "/users/{userId}/folders/{folderId}",
        "definition": { "entityName": "Folder", "description": "Document vault folders." }
      },
      {
        "path": "/blacklist/{uid}",
        "definition": { "entityName": "BlacklistedUser", "description": "Global list of banned credentials." }
      },
      {
        "path": "/ai_usage/{usageId}",
        "definition": { "entityName": "AIUsage", "description": "Monthly AI usage tracking." }
      }
    ]
  }
}
