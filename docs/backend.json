
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and general settings within the FynWealth application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredCurrency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "AppStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppStats",
      "type": "object",
      "description": "Global application metrics used for the admin dashboard.",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalReminders": { "type": "number" },
        "activeUsers24h": { "type": "number" }
      }
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Records individual spending transactions.",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "billImageData": { "type": "string", "description": "Base64 encoded receipt image." },
        "folderId": { "type": "string", "description": "ID of the folder this document is in." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "description", "category", "date", "status"]
    },
    "Bill": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bill",
      "type": "object",
      "description": "Recurring bill reminders.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "dueTime": { "type": "string" },
        "frequency": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "notified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Custom user-defined category.",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Folder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Folder",
      "type": "object",
      "description": "Folders for organizing documents in the vault.",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "description": "User profiles." }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Spending records." }
      },
      {
        "path": "/users/{userId}/bills/{billId}",
        "definition": { "entityName": "Bill", "description": "Recurring bill reminders." }
      },
      {
        "path": "/users/{userId}/categories/{categoryId}",
        "definition": { "entityName": "Category", "description": "Custom expense categories." }
      },
      {
        "path": "/users/{userId}/budgets/{budgetId}",
        "definition": { "description": "Category specific budget limits." }
      },
      {
        "path": "/users/{userId}/folders/{folderId}",
        "definition": { "entityName": "Folder", "description": "Document vault folders." }
      }
    ]
  }
}
