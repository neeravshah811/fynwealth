
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * Enforce strict user-ownership.
     * Access is denied by default.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email != null && (
          request.auth.token.email == 'admin@fynwealth.com' ||
          request.auth.token.email.matches('.*@fynwealth.com')
        )
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user owns the document based on a userId field.
     * Works for both existing resources and incoming requests.
     */
    function ownsDocument() {
      return isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /{allUserData=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /ai_usage/{usageId} {
      // Allow read/write if the document ID matches the pattern {uid}_{month}
      // or if the document contains the correct userId field.
      allow read, write: if isSignedIn() && (isAdmin() || ownsDocument() || usageId.startsWith(request.auth.uid));
    }

    match /statement_results/{resultId} {
      allow read, write: if ownsDocument() || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /subcategories/{subcategoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if isSignedIn();
      // Allow standard users to increment stats (e.g. during signup)
      allow write: if isAdmin() || (docId == 'appStats' && isSignedIn());
    }

    match /featureRequests/{requestId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isAdmin();
    }

    match /blacklist/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsDocument() || isAdmin();
    }

    match /uploads/{uploadId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsDocument() || isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
