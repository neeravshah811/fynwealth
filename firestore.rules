
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model while providing secure 
     * administrative oversight. Security is managed through structural segregation 
     * and data denormalization.
     */

    // --- Global Helper Functions ---

    /**
     * @description Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the super-admin or an authorized administrator.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@fynwealth.com' ||
        request.auth.token.email.matches('.*@fynwealth.com')
      );
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Global Categories and Subcategories. 
     * Users can create their own entries marked with their UID.
     */
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin(); // Global admin fallback
    }

    match /subcategories/{subcategoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin(); // Global admin fallback
    }

    /**
     * @description User Profiles and all private sub-data (expenses, budgets, bills, folders, etc.)
     * Uses recursive matching to ensure all nested paths are covered by owner-only logic.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /{allUserData=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description System-defined categories. Globally readable.
     */
    match /system_categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Application-wide analytics and statistics.
     */
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Registry of authorized administrators.
     */
    match /admins/{adminId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description User-submitted feature requests.
     */
    match /featureRequests/{requestId} {
      allow create: if isSignedIn();
      // Allow admins to manage (read, update, delete) feature requests
      allow get, list, update, delete: if isAdmin();
    }

    /**
     * @description List of blacklisted UIDs who are banned from logging in.
     */
    match /blacklist/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
