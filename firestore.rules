
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@fynwealth.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Core application metrics - readable by all authenticated users
    match /analytics/appStats {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admins registry - users can query to verify their own role
    match /admins {
      allow list: if isSignedIn();
      
      match /{adminId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User-specific data protection
    match /users/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /bills/{billId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Catch-all for analytics and other paths for admins
    match /{document=**} {
      allow read: if isAdmin();
    }
  }
}
