rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model while providing secure 
     * administrative oversight. Security is managed through structural segregation 
     * and data denormalization.
     */

    // --- Global Helper Functions ---

    /**
     * @description Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the super-admin or an authorized administrator.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@fynwealth.com' ||
        request.auth.token.email.matches('.*@fynwealth.com')
      );
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and all private sub-data (expenses, budgets, bills, etc.)
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();

      // Recursive match for all user-owned subcollections (expenses, budgets, categories, billDefinitions)
      // This ensures that any sub-path correctly inherits ownership logic.
      match /{allUserData=**} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description System-defined categories. Globally readable.
     */
    match /system_categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Application-wide analytics and statistics.
     * @path /analytics/{docId}
     */
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Registry of authorized administrators.
     * @path /admins/{adminId}
     */
    match /admins/{adminId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description User-submitted feature requests.
     * @path /featureRequests/{requestId}
     */
    match /featureRequests/{requestId} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
    }
  }
}