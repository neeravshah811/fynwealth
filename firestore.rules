
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@fynwealth.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Admins can read everything for monitoring
    match /{document=**} {
      allow read: if isAdmin();
    }

    // Admin collection rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    match /admins {
      allow list: if isSignedIn();
    }

    // User data rules
    match /users/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /bills/{billId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // App Stats - Allow all signed-in users to read basic app metrics
    match /analytics/appStats {
      allow read: if isSignedIn();
      allow write: if false; 
    }
    
    // Catch-all for analytics sub-paths
    match /analytics/{docId} {
      allow read: if isAdmin();
    }
  }
}
