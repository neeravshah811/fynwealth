
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * Enforce strict user-ownership while providing secure administrative oversight.
     * All data access is blocked by default and permitted only via explicit rules.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email != null && (
          request.auth.token.email == 'admin@fynwealth.com' ||
          request.auth.token.email.matches('.*@fynwealth.com')
        )
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsDocument() {
      return isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and nested data (expenses, budgets, bills, folders, etc.)
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /{allUserData=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description AI Usage Tracking (Monthly Quotas)
     */
    match /ai_usage/{usageId} {
      allow read, write: if ownsDocument() || isAdmin();
    }

    /**
     * @description Statement Analysis Results
     */
    match /statement_results/{resultId} {
      allow read, write: if ownsDocument() || isAdmin();
    }

    /**
     * @description Global Categories and Subcategories
     */
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /subcategories/{subcategoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    /**
     * @description Administrative collections
     */
    match /admins/{adminId} {
      // Standard users read this to check their own role in AuthGuard
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /analytics/{docId} {
      // Standard users need read/write to increment totalUsers in appStats during signup
      allow read: if isSignedIn();
      allow write: if isAdmin() || (docId == 'appStats' && isSignedIn());
    }

    match /featureRequests/{requestId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isAdmin();
    }

    match /blacklist/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    /**
     * @description Optional top-level collections
     */
    match /transactions/{transactionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsDocument() || isAdmin();
    }

    match /uploads/{uploadId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if ownsDocument() || isAdmin();
    }

    /**
     * @description Default Fallback - Deny all access
     */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
