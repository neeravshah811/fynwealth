rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@fynwealth.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Core application metrics - readable by all registered users for dashboard summaries
    match /analytics/appStats {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Global administrative read access for monitoring all documents
    match /{document=**} {
      allow read: if isAdmin();
    }

    // Admins registry - users can read to verify their own role
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    match /admins {
      allow list: if isSignedIn();
    }

    // User-specific data protection
    match /users/{userId} {
      // Users can manage their own profile and records
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      // Admins can list all users for management
      allow list: if isAdmin();

      // Sub-collections inherit access based on ownership
      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /bills/{billId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Catch-all for analytics sub-paths
    match /analytics/{docId} {
      allow read: if isAdmin();
    }
  }
}