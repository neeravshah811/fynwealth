
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        exists(/databases/$(database)/documents/admins/admin_list) && get(/databases/$(database)/documents/admins/admin_list).data.emails.hasAny([request.auth.token.email])
      );
    }

    // Admins can read everything for monitoring
    match /{document=**} {
      allow read: if isAdmin();
    }

    // Admin email list - allow authenticated users to read/list for role verification
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Firebase Console for security
    }
    
    match /admins {
      allow list: if isSignedIn();
    }

    // User data rules
    match /users/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /bills/{billId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // App Stats
    match /analytics/appStats {
      allow read: if isSignedIn();
      allow write: if false; // Updated via Cloud Functions (simulated via triggers)
    }
  }
}
